# 이 파일은 "예시"입니다. 실제로 쓰는 값은 .env 파일에 옮겨 적고,
# .env 파일은 git에 커밋하지 않습니다(.gitignore에 등록되어 있음).

# DB 접속 URL — PostgreSQL + asyncpg
# docker-compose의 db 서비스를 그대로 쓰는 기본 값입니다.
DATABASE_URL=postgresql+asyncpg://note_user:note_pass@localhost:5432/note_api

# JWT 서명에 쓰는 비밀키.
# 운영 환경에서는 반드시 다음과 같이 강한 난수를 새로 생성해 넣으세요.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=please-change-this-to-32-bytes-or-longer-random-string

# JWT 알고리즘 — 이 가이드는 HS256 고정
ALGORITHM=HS256

# 액세스 토큰 만료 시간(분)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS 허용 오리진(쉼표로 구분, "*"이면 모두 허용)
CORS_ALLOW_ORIGINS=*
