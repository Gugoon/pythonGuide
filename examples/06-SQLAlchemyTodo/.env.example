# 이 파일을 .env 로 복사한 뒤 필요에 따라 수정하세요.
# .env 자체는 git 에 올리지 마세요(.gitignore 참고).

# 개발 기본값: 현재 폴더의 todo.db SQLite 파일
DATABASE_URL=sqlite+aiosqlite:///./todo.db

# PostgreSQL 로 옮길 때 예시
# DATABASE_URL=postgresql+asyncpg://todouser:todopass@localhost:5432/tododb

# MySQL 로 옮길 때 예시
# DATABASE_URL=mysql+asyncmy://todouser:todopass@localhost:3306/tododb
