# 이 파일은 "예시"입니다. 실제로 쓰는 값은 .env 파일에 옮겨 적고,
# .env 파일은 git에 커밋하지 않습니다(.gitignore에 등록되어 있음).

# DB 접속 URL. 기본값은 같은 폴더에 todo.db 파일을 만드는 SQLite입니다.
# - SQLite (개발/학습):  sqlite+aiosqlite:///./todo.db
# - PostgreSQL (운영):   postgresql+asyncpg://user:password@localhost:5432/todo
DATABASE_URL=sqlite+aiosqlite:///./todo.db

# CORS 허용 도메인. 콤마로 구분. 개발 단계에서는 * 도 가능합니다.
CORS_ALLOW_ORIGINS=*

# 앱 표시용 이름
APP_NAME=Todo API
